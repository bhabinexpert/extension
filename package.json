{
  "name": "instagram-sidecar-vscode",
  "displayName": "Instagram Reels Sidecar",
  "description": "VS Code extension that opens Instagram in an external browser sidecar while you keep coding.",
  "version": "0.0.1",
  "publisher": "bhabin-local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhabin/instagram-sidecar-vscode"
  },
  "homepage": "https://github.com/bhabin/instagram-sidecar-vscode#readme",
  "bugs": {
    "url": "https://github.com/bhabin/instagram-sidecar-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "instagram",
    "reels",
    "sidecar",
    "browser",
    "productivity",
    "vscode-extension"
  ],
  "activationEvents": [
    "onCommand:instagramSidecar.openLogin",
    "onCommand:instagramSidecar.openReels",
    "onCommand:instagramSidecar.scrollNext",
    "onCommand:instagramSidecar.scrollPrevious",
    "onCommand:instagramSidecar.refresh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "instagramSidecar.openLogin",
        "title": "Instagram Sidecar: Open Login"
      },
      {
        "command": "instagramSidecar.openReels",
        "title": "Instagram Sidecar: Open Reels"
      },
      {
        "command": "instagramSidecar.scrollNext",
        "title": "Instagram Sidecar: Next Reel"
      },
      {
        "command": "instagramSidecar.scrollPrevious",
        "title": "Instagram Sidecar: Previous Reel"
      },
      {
        "command": "instagramSidecar.refresh",
        "title": "Instagram Sidecar: Refresh Sidecar"
      }
    ],
    "configuration": {
      "title": "Instagram Reels Sidecar",
      "properties": {
        "instagramSidecar.sidecarWidth": {
          "type": "number",
          "default": 430,
          "minimum": 320,
          "maximum": 900,
          "description": "Width of the external browser sidecar window in pixels."
        },
        "instagramSidecar.sidecarHeight": {
          "type": "number",
          "default": 900,
          "minimum": 480,
          "maximum": 1600,
          "description": "Height of the external browser sidecar window in pixels."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^3.2.2"
  }
}
